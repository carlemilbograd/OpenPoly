# ─────────────────────────────────────────────────────────────
#  Polymarket Trader — OpenClaw Skill
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Required: your Polygon/Ethereum private key (hex with 0x prefix)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Required for email/Magic wallet (proxy wallet) — leave blank for MetaMask/EOA
POLYMARKET_FUNDER_ADDRESS=

# Signature type: 0 = MetaMask/EOA (default), 1 = Magic/email wallet
POLYMARKET_SIGNATURE_TYPE=0

# Auto-populated by setup_credentials.py — do NOT set manually
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
