# ─────────────────────────────────────────────────────────────
#  Polymarket Trader — OpenClaw Skill
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Required: your Polygon/Ethereum private key (hex with 0x prefix)
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Required for email/Magic wallet (proxy wallet) — leave blank for MetaMask/EOA
POLYMARKET_FUNDER_ADDRESS=

# Signature type:
#   0 = MetaMask / hardware wallet (EOA) — funder address not required
#   1 = POLY_PROXY — email/Google via Magic Link (export key from polymarket.com settings)
#   2 = GNOSIS_SAFE — most common for web signups; export key from polymarket.com settings
# For types 1 and 2, set POLYMARKET_FUNDER_ADDRESS to the address shown on polymarket.com
POLYMARKET_SIGNATURE_TYPE=0

# Auto-populated by setup_credentials.py — do NOT set manually
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
# Optional: NewsAPI key — only needed for the NewsAPI source in the news pipeline
NEWSAPI_KEY=

# Optional: proxy to bypass geo-restrictions (geo-block, travel, etc.)
# Supports http://, https://, socks5://, socks5h:// (socks5h = remote DNS, recommended for full bypass)
# All traffic: CLOB orders, Gamma API, Data API — everything routes through this proxy.
#
# Reverse SSH SOCKS5 tunnel (most common — no VPN software needed):
#   On your local machine run:  ssh -D 1080 -N user@unrestricted-server
#   Then set:
# POLYMARKET_PROXY=socks5h://127.0.0.1:1080
#
# Local HTTP proxy (Privoxy, Squid, Clash, etc.):
# POLYMARKET_PROXY=http://127.0.0.1:8118
#
# Leave blank to use a direct connection (no proxy):
POLYMARKET_PROXY=